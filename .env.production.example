# ============================================================
# Production Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# Database
POSTGRES_USER=pmuser
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=project_management
DATABASE_URL=postgresql://pmuser:change_me_strong_password@postgres:5432/project_management

# Redis
REDIS_PASSWORD=change_me_redis_password
REDIS_URL=redis://:change_me_redis_password@redis:6379

# JWT Secrets (use strong random strings, at least 64 chars)
JWT_SECRET=replace_with_strong_random_secret_at_least_64_characters_long
JWT_REFRESH_SECRET=replace_with_another_strong_random_secret_at_least_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS - comma-separated list of allowed origins
ALLOWED_ORIGINS=https://yourdomain.com

# Frontend WebSocket URL (used at build time)
VITE_REALTIME_URL=https://yourdomain.com

# Email (for password reset)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=noreply@yourdomain.com
